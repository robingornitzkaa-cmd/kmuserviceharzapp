# Environment variables for Founder OS (KMU Service Harz)
# Copy this file to '.env' and fill in your values.
# IMPORTANT: Never commit '.env' to version control!

# Supabase backend connection parameters
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SHA-256 Hash of the password required to access the application.
# Example: If your password is "Harz2026", the SHA-256 hash is:
# "04a6015c7e3a985f4625b306138d6dfd0658cb0e25868e4bfdcd4e8c56fa980f"
# You can generate hashes online or via the command line: echo -n "Password" | sha256sum
VITE_APP_PASSWORD_HASH=your-sha256-password-hash-here
